diff --git a/Makefile b/Makefile
index 932eccb4..bf181692 100644
--- a/Makefile
+++ b/Makefile
@@ -121,7 +121,7 @@ ifneq (,$(findstring unix,$(platform)))
    endif
    fpic = -fPIC
 
-   HAVE_THR_AL=1
+   HAVE_THR_AL=0
    LDFLAGS += -lpthread
    # clock_gettime (libretro-common features_cpu.c) lives in librt on
    # pre-2.17 glibc and some cross toolchains; harmless on modern glibc
@@ -136,6 +136,24 @@ ifneq (,$(findstring unix,$(platform)))
       GLES = 1
    endif
 
+   # RK3326
+   ifneq (,$(findstring RK3326,$(platform)))
+      TARGET := $(TARGET_NAME)_libretro.so
+      CPUFLAGS += -DARM_FIX -DCLASSIC
+      GLES = 1
+      GL_LIB := -lGLESv2
+      WITH_DYNAREC = aarch64
+   endif
+
+   # RK3399
+   ifneq (,$(findstring RK3399,$(platform)))
+      TARGET := $(TARGET_NAME)_libretro.so
+      CPUFLAGS += -DARM_FIX -DCLASSIC
+      GLES = 1
+      GL_LIB := -lGLESv2
+      WITH_DYNAREC = aarch64
+   endif
+
    # Raspberry Pi
    ifneq (,$(findstring rpi,$(platform)))
       GLES = 1
